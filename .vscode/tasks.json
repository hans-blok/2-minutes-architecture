    {
      "label": "DB: flyway clean",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "infra/docker-compose.yml",
        "run",
        "--rm",
        "-e",
        "FLYWAY_CLEAN_DISABLED=false",
        "flyway",
        "clean"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "DB: flyway migrate",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "$logDir = 'logs'; if (-not (Test-Path $logDir)) { New-Item -ItemType Directory -Path $logDir | Out-Null }; $logFile = \"$logDir/flyway-migrate-$(Get-Date -Format 'yyyyMMdd-HHmmss').log\"; Write-Host \"Log: $logFile\"; docker compose -f infra/docker-compose.yml run --rm flyway migrate 2>&1 | Tee-Object -FilePath $logFile; $rc = $LASTEXITCODE; if (Select-String -Path $logFile -Pattern 'ERROR|FAILED|Migration.*failed|Unable to' -Quiet) { Write-Host ''; Write-Host 'WAARSCHUWING: Fouten gevonden in Flyway output. Zie log: ' $logFile -ForegroundColor Red }; exit $rc"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
